rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /orders/{orderId}/{fileName} {
      // أي مستخدم مسجّل دخول يقدر يرفع صورة الطلب (وقت إنشاء الطلب)
      allow write: if request.auth != null;
      // أي مستخدم مسجّل دخول يقدر يشوف الصورة (تبسيطًا؛ الحماية الفعلية
      // على مستوى الطلب نفسه موجودة في Firestore)
      allow read: if request.auth != null;
    }
  }
}
